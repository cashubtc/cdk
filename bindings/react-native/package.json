{
  "name": "@cashudevkit/react-native",
  "version": "0.1.0",
  "description": "React Native Nitro bindings for Cashu Development Kit",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "files": [
    "src",
    "lib",
    "cpp",
    "android",
    "ios",
    "nitrogen",
    "*.podspec",
    "nitro.json"
  ],
  "scripts": {
    "build": "bob build",
    "codegen": "nitro-codegen",
    "prepack": "bob build"
  },
  "keywords": ["react-native", "cashu", "ecash", "nitro"],
  "license": "MIT",
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-nitro-modules": "*"
  },
  "devDependencies": {
    "react-native-nitro-codegen": "^0.19.0",
    "react-native-builder-bob": "^0.30.0",
    "typescript": "^5.4.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": ["commonjs", "module", "typescript"]
  }
}
